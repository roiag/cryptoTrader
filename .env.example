# ── Bybit ──────────────────────────────────────────────────────────────────────
# Paper trading (testnet): https://testnet.bybit.com → API Management
# Live trading:            https://www.bybit.com     → API Management
BYBIT_API_KEY=your_api_key_here
BYBIT_SECRET=your_secret_here
PAPER_TRADING=true          # true = testnet | false = live

# ── Claude API ─────────────────────────────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Telegram Alerts ────────────────────────────────────────────────────────────
# 1. פתח @BotFather ב-Telegram → /newbot → קבל TOKEN
# 2. שלח הודעה לבוט שלך
# 3. https://api.telegram.org/bot<TOKEN>/getUpdates → קבל chat_id
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── News (אופציונלי - משפר את ה-Sentiment Agent) ───────────────────────────────
# הרשמה חינמית: https://cryptopanic.com/developers/api/
CRYPTOPANIC_TOKEN=

# ── Trading Config ─────────────────────────────────────────────────────────────
TIMEFRAME=15m               # 1m | 5m | 15m | 30m | 1h | 4h
CANDLES_LIMIT=200
RUN_INTERVAL_MINUTES=15     # כל כמה דקות להריץ pipeline

# ── Risk ───────────────────────────────────────────────────────────────────────
MAX_RISK_PER_TRADE=0.01     # 1% מהתיק לעסקה (אל תשנה ללא הבנה מלאה)
MAX_DAILY_LOSS=0.05         # 5% - circuit breaker יומי
MAX_OPEN_POSITIONS=3        # מקסימום פוזיציות פתוחות במקביל
