# Force LF line endings for shell scripts (prevents \r errors on Linux/Mac)
*.sh    text eol=lf
*.bash  text eol=lf

# Windows scripts stay CRLF
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Python and text files — normalize
*.py    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.env   text eol=lf
